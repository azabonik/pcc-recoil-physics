---
interface WeightRow {
  weight: string;          // "95gr"
  velocity: string;        // "1,368 fps"
  /** Net felt-recoil delta between fast and slow at this weight, e.g. "~6%". */
  recoilDelta: string;
  color: 'accent' | 'cyan' | 'blue';
  /** Gas momentum (gr·fps) for the fast-powder load. */
  fastGas: number;
  /** Gas momentum (gr·fps) for the slow-powder load. */
  slowGas: number;
  /** Slow-vs-fast multiplier, e.g. "2.7×". */
  multiplier: string;
}

interface Props {
  rows: WeightRow[];
}

const { rows } = Astro.props;

// Common scale across all rows so bar lengths are comparable. The slow bar of
// the load with the most gas (typically 95gr slow ≈ 14,774) anchors 100%.
const globalMax = Math.max(...rows.flatMap((r) => [r.fastGas, r.slowGas]));
const widthPct = (v: number) => Math.max((v / globalMax) * 100, 1.5);
const fmt = (n: number) => new Intl.NumberFormat('en-US').format(n);

const colorVar = (c: WeightRow['color']) =>
  c === 'accent' ? 'var(--accent)' : c === 'cyan' ? 'var(--cyan)' : 'var(--blue)';
---
<div class="gas-chart">
  <div class="gas-chart-head">
    <div class="gas-chart-title">Gas momentum by powder choice</div>
    <p>
      All loads here are 130 PF from a 13″ PCC. Bullet momentum is locked at
      ~130,000 gr·fps in every row — that's what holding PF constant means.
      The only thing that changes is how much gas exits the muzzle and how fast.
      The bars below show <strong>only the gas portion</strong>, scaled to a
      common axis so you can compare across loads at a glance.
    </p>
  </div>

  {rows.map((row) => (
    <div class="gas-row" style={`--row-color:${colorVar(row.color)};`}>
      <div class="gas-row-head">
        <div class="gas-row-label">
          <span class="gas-weight">{row.weight}</span>
          <span class="gas-velocity">· {row.velocity}</span>
        </div>
        <div class="gas-row-delta">
          felt recoil Δ <strong>{row.recoilDelta}</strong>
        </div>
      </div>

      <div class="gas-bars">
        <div class="gas-bar-line">
          <span class="gas-bar-tag fast">FAST</span>
          <div class="gas-bar-track">
            <div class="gas-bar-fill green" style={`width:${widthPct(row.fastGas)}%;`}></div>
          </div>
          <span class="gas-bar-num">{fmt(row.fastGas)}</span>
          <span class="gas-bar-mult-spacer"></span>
        </div>
        <div class="gas-bar-line">
          <span class="gas-bar-tag slow">SLOW</span>
          <div class="gas-bar-track">
            <div class="gas-bar-fill red" style={`width:${widthPct(row.slowGas)}%;`}></div>
          </div>
          <span class="gas-bar-num">{fmt(row.slowGas)}</span>
          <span class="gas-bar-mult">{row.multiplier}</span>
        </div>
      </div>
    </div>
  ))}

  <div class="gas-chart-foot">
    <div class="gas-foot-title">Why dramatic gas change → modest felt recoil change?</div>
    <p>
      Because gas momentum is only 4–10% of total recoil momentum at these loads.
      Tripling a small slice still adds up to a small slice. But your shoulder,
      ear, and face do not weight-average like an equation does — section 5 covers
      the perceptual factors (blast, sound, impulse shape) that make the felt
      difference register much larger than the ~5–6% momentum number suggests.
    </p>
  </div>

  <slot name="footer" />
</div>

<style>
  .gas-chart {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 28px 32px;
    margin: 28px 0;
  }
  .gas-chart-head { margin-bottom: 24px; }
  .gas-chart-title {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 10px;
  }
  .gas-chart-head p {
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.6;
    margin: 0;
    max-width: 760px;
  }
  .gas-chart-head strong { color: var(--text); font-weight: 600; }

  /* Per-weight row */
  .gas-row {
    padding: 18px 0;
    border-top: 1px solid var(--border);
  }
  .gas-row-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 12px;
    gap: 12px;
    flex-wrap: wrap;
  }
  .gas-row-label {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 600;
  }
  .gas-weight { color: var(--row-color); font-size: 16px; }
  .gas-velocity { color: var(--text-dim); font-weight: 500; margin-left: 4px; }
  .gas-row-delta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-dim);
    letter-spacing: 0.5px;
  }
  .gas-row-delta strong { color: var(--row-color); font-weight: 700; font-size: 14px; }

  /* Bar lines */
  .gas-bars { display: flex; flex-direction: column; gap: 6px; }
  .gas-bar-line {
    display: grid;
    grid-template-columns: 52px 1fr 70px 56px;
    gap: 12px;
    align-items: center;
  }
  .gas-bar-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    text-align: right;
  }
  .gas-bar-tag.fast { color: var(--green); }
  .gas-bar-tag.slow { color: var(--red); }

  .gas-bar-track {
    height: 22px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 3px;
    overflow: hidden;
  }
  .gas-bar-fill {
    height: 100%;
    transition: width 200ms ease;
  }
  .gas-bar-fill.green { background: var(--green); }
  .gas-bar-fill.red { background: var(--red); }

  .gas-bar-num {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-bright);
    font-variant-numeric: tabular-nums;
  }
  .gas-bar-mult, .gas-bar-mult-spacer {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 700;
    color: var(--red);
    text-align: left;
  }
  .gas-bar-mult::before { content: '↑ '; opacity: 0.7; }
  .gas-bar-mult-spacer { content: ''; visibility: hidden; }

  /* Footer summary */
  .gas-chart-foot {
    margin-top: 22px;
    padding: 16px 18px;
    background: var(--bg-card-alt);
    border-radius: 4px;
    border-left: 2px solid var(--accent);
  }
  .gas-foot-title {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 8px;
  }
  .gas-chart-foot p {
    font-size: 13px;
    color: var(--text);
    line-height: 1.6;
    margin: 0;
    max-width: 760px;
  }

  @media (max-width: 600px) {
    .gas-chart { padding: 20px 16px; }
    .gas-bar-line {
      grid-template-columns: 42px 1fr 60px 44px;
      gap: 8px;
    }
    .gas-bar-tag { font-size: 10px; }
    .gas-bar-num { font-size: 11px; }
    .gas-bar-mult { font-size: 12px; }
    .gas-row-label { font-size: 13px; }
    .gas-weight { font-size: 14px; }
    .gas-row-delta { font-size: 11px; }
    .gas-row-delta strong { font-size: 13px; }
  }
</style>
